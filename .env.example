# DishSpace AI Environment Configuration
# Copy to .env and fill in values

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Modal ──
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ── API ──
DISHSPACE_API_KEY=dev-key-change-me
API_HOST=0.0.0.0
API_PORT=8000

# ── Model ──
BASE_MODEL=physical-intelligence/pi0-base
LORA_ADAPTER_PATH=models/dora/kitchen_default_v0.2
DEFAULT_KITCHEN_PROFILE=default
DEVICE=cuda

# ── Paths / Storage ──
DISHSPACE_ROOT=
DATA_DIR=
MODELS_DIR=
CACHE_DIR=
HF_HOME=
TRANSFORMERS_CACHE=
HUGGINGFACE_HUB_CACHE=

# ── Runpod ──
RUNPOD_VOLUME_ROOT=
RUNPOD_POD_ID=
HF_TOKEN=

# ── Depth & Segmentation Foundation Models ──
DEPTH_MODEL=depth-anything/Depth-Anything-V2-Large
SEG_MODEL=IDEA-Research/grounding-dino-base
SAM_MODEL=facebook/sam2-hiera-large

# ── Inference ──
MAX_GRASPS=5
MIN_CONFIDENCE=0.7
COLLISION_CHECK=true
DEPTH_COMPLETION=depth_anything_v2
SEGMENTATION=grounded_sam2

# ── Logging ──
LOG_LEVEL=INFO
SENTRY_DSN=
